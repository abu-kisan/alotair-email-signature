{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": []
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Helvetica Neue LT Arabic|Roboto))/i]",
        "message": "Font not provided by the design system. Available: Helvetica Neue LT Arabic, Roboto."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--accent",
      "--accent-cool",
      "--border-strong",
      "--border-subtle",
      "--color-black",
      "--color-charcoal",
      "--color-gold",
      "--color-gold-deep",
      "--color-gold-soft",
      "--color-lightblue",
      "--color-navy",
      "--color-navy-300",
      "--color-navy-700",
      "--color-navy-print",
      "--color-offwhite",
      "--color-slate",
      "--color-white",
      "--font-ar",
      "--font-ar-safe",
      "--font-en",
      "--fs-body",
      "--fs-caption",
      "--fs-display",
      "--fs-h1",
      "--fs-h2",
      "--fs-h3",
      "--fs-lead",
      "--fs-small",
      "--lh-body",
      "--lh-snug",
      "--lh-tight",
      "--ls-normal",
      "--ls-tight",
      "--ls-wide",
      "--radius-lg",
      "--radius-md",
      "--radius-pill",
      "--radius-sm",
      "--shadow-lg",
      "--shadow-md",
      "--shadow-sm",
      "--space-1",
